DATABASE_URL=file:./data/coredot.db
DATABASE_AUTH_TOKEN=
TURSO_AUTH_TOKEN=
AUTH_MODE=test
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
TEST_PRINCIPAL_ID=test:principal:local
TEST_WORKSPACE_ID=test:workspace:local
TEST_IDENTITY_SIGNING_SECRET=
# Next.js Web process only. Never provide this private signer ring to the sidecar.
COLLABORATION_CAPABILITY_SIGNING_KEY_RING=
# Collaboration sidecar process only. This ring contains public verification JWKs.
# Deploy the Web and sidecar with separate environment allowlists; the sidecar
# intentionally rejects COLLABORATION_CAPABILITY_SIGNING_KEY_RING when present.
COLLABORATION_CAPABILITY_VERIFICATION_KEY_RING=
COLLABORATION_SERVER_ADDRESS=127.0.0.1
COLLABORATION_SERVER_PORT=1234
COLLABORATION_SHUTDOWN_GRACE_MS=10000
COLLABORATION_ALLOWED_HOSTS=127.0.0.1
COLLABORATION_ALLOWED_ORIGINS=http://127.0.0.1:3000
PROJECT_PROFILE_ID=default
CONVERSATION_STORAGE=database
AI_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
COREDOT_API_KEY=
COREDOT_MODEL=gpt-5-nano
COREDOT_BASE_URL=https://api.core.today/llm/openai/v1
COREDOT_ANTHROPIC_MODEL=claude-sonnet-4.5
COREDOT_ANTHROPIC_BASE_URL=https://api.core.today/llm/anthropic/v1
COREDOT_GEMINI_MODEL=gemini-2.5-flash
COREDOT_GEMINI_BASE_URL=https://api.core.today/llm/gemini/v1beta
COREDOT_MAX_COMPLETION_TOKENS=32768
