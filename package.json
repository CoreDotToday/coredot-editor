{
  "name": "coredot-editor",
  "version": "1.0.0",
  "description": "Open-source AI document editor starter built with Next.js, Tiptap, Drizzle, SQLite, and the Vercel AI SDK.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "ai-editor",
    "document-editor",
    "nextjs",
    "tiptap",
    "drizzle",
    "vercel-ai-sdk",
    "openai",
    "sqlite"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "pnpm build:docx-worker && next build",
    "build:docx-worker": "esbuild src/features/documents/docx-conversion-worker.mjs --bundle --platform=node --format=cjs --target=node22 --outfile=src/features/documents/.generated/docx-conversion-worker.cjs",
    "collaboration:build": "esbuild src/features/collaboration/server/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=src/features/collaboration/server/.generated/server.mjs",
    "collaboration:dev": "tsx watch src/features/collaboration/server/index.ts",
    "collaboration:verify-runtime": "tsx scripts/collaboration/verify-runtime.ts",
    "start": "node scripts/validate-production-auth.mjs --production && next start",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:collaboration": "vitest run scripts/collaboration src/features/collaboration",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:claim-local-workspace": "tsx scripts/db/claim-local-workspace.ts",
    "ai:recover-stale-runs": "tsx scripts/ai/recover-stale-runs.ts",
    "docs:serve": "python3 -m mkdocs serve",
    "docs:build": "python3 -m mkdocs build --strict",
    "docs:capture": "tsx scripts/docs/capture-assets.ts",
    "docs:check-links": "tsx scripts/docs/check-links.ts",
    "docs:check-links:external": "tsx scripts/docs/check-links.ts --external",
    "docs:verify-quick-start": "tsx scripts/docs/verify-quick-start.ts",
    "docker:rag:up": "bash scripts/rag/verify-docker-env.sh up",
    "docker:rag:down": "bash scripts/rag/verify-docker-env.sh down",
    "docker:rag:verify": "bash scripts/rag/verify-docker-env.sh verify",
    "e2e:prepare": "tsx scripts/e2e/prepare.ts",
    "e2e": "pnpm e2e:prepare && playwright test",
    "e2e:production": "tsx scripts/e2e/run-production-smoke.ts",
    "security:audit": "tsx scripts/security/audit-dependencies.ts",
    "security:verify-auth-startup": "pnpm build:docx-worker && node scripts/security/verify-production-auth-startup.mjs",
    "release:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm e2e && pnpm security:verify-auth-startup && pnpm build && pnpm security:audit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.85",
    "@clerk/nextjs": "^7.5.17",
    "@hocuspocus/provider": "4.4.0",
    "@hocuspocus/server": "4.4.0",
    "@libsql/client": "^0.17.3",
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-character-count": "^3.27.4",
    "@tiptap/extension-collaboration": "3.27.4",
    "@tiptap/extension-collaboration-caret": "3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-placeholder": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-task-item": "^3.27.4",
    "@tiptap/extension-task-list": "^3.27.4",
    "@tiptap/extension-typography": "^3.27.4",
    "@tiptap/html": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@xmldom/xmldom": "^0.8.13",
    "ai": "^6.0.226",
    "docx": "^9.7.1",
    "drizzle-orm": "^0.45.2",
    "happy-dom": "^20.9.0",
    "jszip": "^3.10.1",
    "jose": "6.2.3",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "y-prosemirror": "1.3.7",
    "yjs": "13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.3.0",
    "playwright": "^1.61.1",
    "semver": "^7.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.10",
    "ws": "8.21.1",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "^7.29.6",
      "esbuild": "^0.25.12",
      "js-yaml": "^4.2.0",
      "postcss": "^8.5.14",
      "undici": "^7.28.0",
      "vite": "^8.0.16",
      "ws": "8.21.1"
    }
  }
}
