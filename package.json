{
  "name": "coredot-editor",
  "version": "1.0.0",
  "description": "Open-source AI document editor starter built with Next.js, Tiptap, Drizzle, SQLite, and the Vercel AI SDK.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "ai-editor",
    "document-editor",
    "nextjs",
    "tiptap",
    "drizzle",
    "vercel-ai-sdk",
    "openai",
    "sqlite"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/validate-production-auth.mjs --production && next start",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "docs:serve": "python3 -m mkdocs serve",
    "docs:build": "python3 -m mkdocs build --strict",
    "docker:rag:up": "bash scripts/rag/verify-docker-env.sh up",
    "docker:rag:down": "bash scripts/rag/verify-docker-env.sh down",
    "docker:rag:verify": "bash scripts/rag/verify-docker-env.sh verify",
    "e2e:prepare": "tsx scripts/e2e/prepare.ts",
    "e2e": "pnpm e2e:prepare && playwright test",
    "security:audit": "pnpm audit --audit-level moderate",
    "security:verify-auth-startup": "node scripts/security/verify-production-auth-startup.mjs",
    "release:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm e2e && pnpm build && pnpm security:audit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@clerk/nextjs": "^7.5.17",
    "@libsql/client": "^0.17.3",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-character-count": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/extension-task-item": "^3.23.1",
    "@tiptap/extension-task-list": "^3.23.1",
    "@tiptap/extension-typography": "^3.23.1",
    "@tiptap/html": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "ai": "^6.0.176",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.2",
    "happy-dom": "^20.9.0",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.12",
      "js-yaml": "^4.2.0",
      "postcss": "^8.5.14",
      "undici": "^7.28.0",
      "vite": "^8.0.16",
      "ws": "^8.21.0"
    }
  }
}
